{
  "manifest_version": 3,
  "name": "Smart Right-Click",
  "version": "1.1.0",
  "description": "Highlight text, right-click, and get instant insights — negative news or a quick summary.",
  "permissions": [
    "contextMenus",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://en.wikipedia.org/*",
    "https://gnews.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Smart Right-Click",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
